# Copy to backend/.env and fill in. backend/.env is gitignored.

# ── NTRIP caster (ZINGSACORS) ──────────────────────────────────────────────────
# Same caster used by the Streamlit live pipeline (.streamlit/secrets.toml [ntrip]).
NTRIP_HOST=
NTRIP_PORT=2101
NTRIP_USERNAME=
NTRIP_PASSWORD=
NTRIP_CONNECTION=TCP
# CORS station code (zgiis/cors/stations.py) this mountpoint belongs to.
# If NTRIP_MOUNTPOINT is ZINGSA_HQ, ZINHQ, ALL, or NETWORK, the backend
# expands it to the built-in 24-station CORS mountpoint registry for the
# live dashboard.
NTRIP_STATION_CODE=zinh
NTRIP_MOUNTPOINT=ZINGSA_HQ
# Stream multiple mountpoints at once: "code:MOUNT,code:MOUNT,...".
# Overrides NTRIP_STATION_CODE / NTRIP_MOUNTPOINT when set. Check the caster's
# actual sourcetable (plain GET / with NTRIP headers) for real mountpoint names
# before assuming they match the station registry codes.
NTRIP_MOUNTPOINTS=
# Direct verification opens an additional caster session per mountpoint. Keep
# disabled when the persistent collector is running or the account is limited.
ENABLE_NTRIP_PROBE=false
# If explicitly enabled, probe sequentially by default to avoid connection bursts.
NTRIP_PROBE_MAX_WORKERS=1
# Optional max mountpoints the persistent live collector holds open at once.
# Leave empty to connect every configured CORS mountpoint. Set a lower number
# only if the caster account rejects too many simultaneous station sessions.
NTRIP_LIVE_MAX_CONCURRENT=

# ── TimescaleDB (optional — falls back to SQLite at static/data/vtec_live.db) ──
# Set this on the persistent collector and on Vercel to the same database so
# production can read live CORS station snapshots written by the collector.
# Vercel Postgres variables POSTGRES_URL or DATABASE_URL are also accepted.
TSDB_DSN=

# ── Space weather logging (dashboard metrics archive) ─────────────────────────
# Interval for background Kp/Dst/F10.7/wind/S4/GNSS/CORS snapshot logging.
SW_LOG_INTERVAL_SEC=60
# Minimum seconds between duplicate writes (dashboard refresh + scheduler).
SW_LOG_MIN_GAP_SEC=45

# ── CORS station status logging (online / degraded / offline) ─────────────────
# Background poll interval and minimum gap between polls from API routes.
STATION_STATUS_POLL_SEC=60
STATION_STATUS_MIN_GAP_SEC=45
# How far back Vercel/API reads may trust archived live CORS station snapshots.
LIVE_STATUS_ARCHIVE_HOURS=1

# ── NASA DONKI (solar flares, CMEs, geomagnetic storms) ─────────────────────
# Free key: https://api.nasa.gov/ — DEMO_KEY works for local dev (30 req/hr/IP).
NASA_API_KEY=DEMO_KEY

# ── API auth (optional — open access in dev when unset) ───────────────────────
API_KEY=

# ── Navigation News broadcast agent (scripts/navigation_broadcast_agent.py) ───
# API to fetch briefs (defaults to production if unset)
NAVIGATION_NEWS_API_URL=https://zingsa-gnss-tec.vercel.app
NAVIGATION_NEWS_API_KEY=
# true = log/file only; false = post to WhatsApp/Facebook/webhooks
BROADCAST_DRY_RUN=true
BROADCAST_INTERVAL_MIN=120
BROADCAST_AUDIENCES=citizen,farmer,surveyor,driver
BROADCAST_STATE_PATH=static/data/broadcast_state.json
BROADCAST_OUT_DIR=static/data/broadcast_out
# Paste contents of config/broadcast_routes.example.json (one line) or set per-channel:
# BROADCAST_ROUTES={"farmer":[{"channel":"whatsapp","script":"broadcast","options":{"to":"263..."}}]}
BROADCAST_ROUTES=
# Or point to a JSON file (see config/broadcast_routes.example.json)
BROADCAST_ROUTES_FILE=
# WhatsApp Cloud API (Meta Business)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Facebook Page post (social_script)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
# X / Twitter (social_script, max 280 chars)
TWITTER_BEARER_TOKEN=
# Optional generic webhook for custom bots
BROADCAST_WEBHOOK_URL=

# ── Geomagnetic storm alerts (SMS, WhatsApp, email) ───────────────────────────
# Triggered on EKF deviation alerts (Moderate+) and Kp ≥ 5 active storms.
# Keep STORM_ALERT_DRY_RUN=true until credentials are configured.
STORM_ALERT_DRY_RUN=true
STORM_ALERT_EMAIL_TO=ops@example.com,science@example.com
STORM_ALERT_SMS_TO=+263771234567
STORM_ALERT_WHATSAPP_TO=263771234567
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@zingsa.co.zw
# SMS (Twilio) — https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890
# WhatsApp uses WHATSAPP_ACCESS_TOKEN and WHATSAPP_PHONE_NUMBER_ID above.

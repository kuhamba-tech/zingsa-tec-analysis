# Copy to backend/.env and fill in. backend/.env is gitignored.

# ── NTRIP caster (ZINGSACORS) ──────────────────────────────────────────────────
# Same caster used by the Streamlit live pipeline (.streamlit/secrets.toml [ntrip]).
NTRIP_HOST=
NTRIP_PORT=2101
NTRIP_USERNAME=
NTRIP_PASSWORD=
NTRIP_CONNECTION=TCP
# CORS station code (zgiis/cors/stations.py) this mountpoint belongs to.
NTRIP_STATION_CODE=zinh
NTRIP_MOUNTPOINT=ZINGSA_HQ
# Stream multiple mountpoints at once: "code:MOUNT,code:MOUNT,...".
# Overrides NTRIP_STATION_CODE / NTRIP_MOUNTPOINT when set. Check the caster's
# actual sourcetable (plain GET / with NTRIP headers) for real mountpoint names
# before assuming they match the station registry codes.
NTRIP_MOUNTPOINTS=

# ── TimescaleDB (optional — falls back to SQLite at static/data/vtec_live.db) ──
TSDB_DSN=

# ── Space weather logging (dashboard metrics archive) ─────────────────────────
# Interval for background Kp/Dst/F10.7/wind/S4/GNSS/CORS snapshot logging.
SW_LOG_INTERVAL_SEC=60
# Minimum seconds between duplicate writes (dashboard refresh + scheduler).
SW_LOG_MIN_GAP_SEC=45

# ── CORS station status logging (online / degraded / offline) ─────────────────
# Background poll interval and minimum gap between polls from API routes.
STATION_STATUS_POLL_SEC=60
STATION_STATUS_MIN_GAP_SEC=45

# ── API auth (optional — open access in dev when unset) ───────────────────────
API_KEY=
